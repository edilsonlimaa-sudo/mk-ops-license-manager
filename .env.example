# ===========================================
# MK-Ops License Manager - Environment Variables
# ===========================================
# 
# Para uso LOCAL:
# 1. Copie este arquivo: cp .env.example .env
# 2. Ajuste os valores conforme necessário
# 3. NUNCA commite o arquivo .env (contém senhas!)
# 
# Para uso no PORTAINER:
# Configure estas variáveis na interface do Portainer
# Veja PORTAINER.md para instruções completas
# ===========================================

# -----------------------------------------
# Database Configuration
# -----------------------------------------

# PostgreSQL User (default: postgres)
POSTGRES_USER=postgres

# PostgreSQL Password (OBRIGATÓRIO - mude para senha segura!)
POSTGRES_PASSWORD=sua_senha_segura_aqui

# PostgreSQL Database Name (default: mkops_licenses)
POSTGRES_DB=mkops_licenses

# -----------------------------------------
# Application Configuration
# -----------------------------------------

# Database Connection String (OBRIGATÓRIO)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# 
# Para Docker Compose (containers na mesma rede):
DATABASE_URL=postgresql://postgres:sua_senha_segura_aqui@db:5432/mkops_licenses
#
# ⚠️ IMPORTANTE: A senha aqui deve ser IGUAL ao POSTGRES_PASSWORD acima!

# Node Environment (default: production)
# Valores: development | production | test
NODE_ENV=production

# Public URL da aplicação (OBRIGATÓRIO)
# Em produção, use a URL pública completa com HTTPS
NEXT_PUBLIC_APP_URL=https://api.mk-ops.com.br

# Application Port (default: 3000)
PORT=3000

# Timezone (default: America/Sao_Paulo)
TZ=America/Sao_Paulo

# ===========================================
# NOTAS IMPORTANTES
# ===========================================
# 
# 1. NUNCA commite o arquivo .env no Git!
# 2. Use senhas fortes e únicas para POSTGRES_PASSWORD
# 3. A senha em DATABASE_URL deve ser IGUAL ao POSTGRES_PASSWORD
# 4. Em produção, use HTTPS no NEXT_PUBLIC_APP_URL
# 5. O host 'db' em DATABASE_URL é o nome do serviço no docker-compose
# 
# ===========================================
